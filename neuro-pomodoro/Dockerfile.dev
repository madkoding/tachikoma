# =============================================================================
# Pomodoro Service Rust - Development Dockerfile
# =============================================================================
# Optimized for fast development builds with mold linker.
# =============================================================================

FROM rust:1.83-slim AS builder

# Install build dependencies + mold linker for faster linking
RUN apt-get update && apt-get install -y \
    pkg-config \
    libssl-dev \
    mold \
    && rm -rf /var/lib/apt/lists/*

# Configure mold as the linker
ENV RUSTFLAGS="-C link-arg=-fuse-ld=mold"

WORKDIR /app

# Copy source
COPY Cargo.toml Cargo.lock* ./
COPY src ./src

# Build in debug mode (faster compilation)
RUN cargo build

# Runtime stage
FROM debian:bookworm-slim

WORKDIR /app

# Install runtime dependencies
RUN apt-get update && apt-get install -y ca-certificates curl && rm -rf /var/lib/apt/lists/*

# Copy binary (debug build)
COPY --from=builder /app/target/debug/neuro-pomodoro /app/neuro-pomodoro

# Set environment
ENV RUST_LOG=info,neuro_pomodoro=debug
ENV PORT=3010

EXPOSE 3010

CMD ["/app/neuro-pomodoro"]
