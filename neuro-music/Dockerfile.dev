# =============================================================================
# Music Service Rust - Development Dockerfile
# =============================================================================
# Optimized for FAST development builds:
# - Uses debug mode (no --release)
# - Persistent cargo cache via volume mount
# - mold linker for faster linking
# - Recompiles on start if source changed
# =============================================================================

FROM rust:1.86-slim

# Install build dependencies + mold linker for faster linking
RUN apt-get update && apt-get install -y \
    pkg-config \
    libssl-dev \
    ffmpeg \
    python3 \
    python3-pip \
    curl \
    mold \
    clang \
    && pip3 install --break-system-packages yt-dlp \
    && rm -rf /var/lib/apt/lists/*

# Configure cargo: use mold linker + max parallel jobs
RUN mkdir -p /root/.cargo && \
    echo '[build]' > /root/.cargo/config.toml && \
    echo 'jobs = -1' >> /root/.cargo/config.toml && \
    echo '' >> /root/.cargo/config.toml && \
    echo '[target.x86_64-unknown-linux-gnu]' >> /root/.cargo/config.toml && \
    echo 'linker = "clang"' >> /root/.cargo/config.toml && \
    echo 'rustflags = ["-C", "link-arg=-fuse-ld=mold"]' >> /root/.cargo/config.toml

# Create downloads directory
RUN mkdir -p /data/downloads

WORKDIR /app

# Copy source files
COPY Cargo.toml Cargo.lock* ./
COPY src ./src

# Pre-build dependencies only (will be cached)
# This creates a dummy main.rs to compile deps, then removes it
RUN mkdir -p src && \
    echo 'fn main() {}' > src/main.rs && \
    cargo build && \
    rm -rf src

# Copy real source (this layer changes when code changes)
COPY src ./src

ENV RUST_LOG=info
ENV MUSIC_PORT=3002
ENV DOWNLOADS_PATH=/data/downloads

EXPOSE 3002

# Compile and run - always recompiles if source changed
# The volume-mounted src will be used, triggering recompilation
CMD cargo build && ./target/debug/neuro-music
