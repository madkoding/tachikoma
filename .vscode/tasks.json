{
  "version": "2.0.0",
  "tasks": [
    // =========================================================================
    // STOP
    // =========================================================================
    {
      "label": "🛑 Stop All",
      "type": "shell",
      "command": "docker compose down --remove-orphans 2>/dev/null; docker rm -f neuro-voice neuro-music neuro-checklists neuro-chat neuro-memory neuro-agent neuro-pomodoro neuro-kanban neuro-note neuro-docs neuro-calendar neuro-image neuro-surrealdb neuro-searxng 2>/dev/null; pkill -f 'cargo watch' 2>/dev/null; pkill -f 'neuro-backend' 2>/dev/null; fuser -k 3000/tcp 5173/tcp 5174/tcp 2>/dev/null; echo '✓ All services stopped'",
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared" }
    },

    // =========================================================================
    // DOCKER SERVICES
    // =========================================================================
    {
      "label": "🐳 Docker (Dev Mode)",
      "detail": "Inicia microservicios Docker con builds rápidos (debug + mold)",
      "type": "shell",
      "command": "./dev.sh docker-dev",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated", "group": "docker" },
      "dependsOn": ["🛑 Stop All"]
    },
    {
      "label": "👁️ Docker (Watch Mode)",
      "detail": "Auto-rebuild cuando cambias código en neuro-*/src",
      "type": "shell",
      "command": "./dev.sh watch",
      "isBackground": true,
      "problemMatcher": {
        "owner": "docker-watch",
        "pattern": { "regexp": "^.*$", "message": 0 },
        "background": { "activeOnStart": true, "beginsPattern": "Watching|watch", "endsPattern": "never-matches" }
      },
      "presentation": { "reveal": "always", "panel": "dedicated", "group": "docker" },
      "dependsOn": ["🛑 Stop All"]
    },

    // =========================================================================
    // BACKEND (Rust)
    // =========================================================================
    {
      "label": "🦀 Backend",
      "detail": "neuro-backend con cargo watch (hot-reload)",
      "type": "shell",
      "command": "fuser -k 3000/tcp 2>/dev/null; sleep 0.3; cd neuro-backend && cargo watch -x run",
      "isBackground": true,
      "options": {
        "env": {
          "DATABASE_URL": "ws://127.0.0.1:8000",
          "DATABASE_USER": "root",
          "DATABASE_PASS": "neuroos_secret_2024",
          "OLLAMA_URL": "http://127.0.0.1:11434",
          "SEARXNG_URL": "http://127.0.0.1:8080",
          "VOICE_SERVICE_URL": "http://127.0.0.1:8100",
          "MUSIC_SERVICE_URL": "http://127.0.0.1:3002",
          "CHECKLISTS_SERVICE_URL": "http://127.0.0.1:3001",
          "CHAT_SERVICE_URL": "http://127.0.0.1:3003",
          "MEMORY_SERVICE_URL": "http://127.0.0.1:3004",
          "AGENT_SERVICE_URL": "http://127.0.0.1:3005",
          "KANBAN_SERVICE_URL": "http://127.0.0.1:3006",
          "NOTE_SERVICE_URL": "http://127.0.0.1:3007",
          "DOCS_SERVICE_URL": "http://127.0.0.1:3008",
          "CALENDAR_SERVICE_URL": "http://127.0.0.1:3009",
          "POMODORO_SERVICE_URL": "http://127.0.0.1:3010",
          "IMAGE_SERVICE_URL": "http://127.0.0.1:3011",
          "RUST_LOG": "info"
        }
      },
      "problemMatcher": {
        "owner": "rust",
        "fileLocation": ["relative", "${workspaceFolder}/neuro-backend"],
        "pattern": { "regexp": "^error\\[E\\d+\\]: (.+)$", "message": 1 },
        "background": { "activeOnStart": true, "beginsPattern": "Compiling|Restarting", "endsPattern": "NEURO-OS Backend ready|Server:" }
      },
      "presentation": { "reveal": "always", "panel": "dedicated", "group": "dev" }
    },

    // =========================================================================
    // FRONTEND (Vite)
    // =========================================================================
    {
      "label": "⚛️ User UI",
      "detail": "neuro-ui en puerto 5173",
      "type": "shell",
      "command": "fuser -k 5173/tcp 2>/dev/null; sleep 0.3; source ~/.nvm/nvm.sh 2>/dev/null; cd neuro-ui && npm run dev",
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": { "regexp": "^(.*):(\\d+):(\\d+): (.*)$", "file": 1, "line": 2, "column": 3, "message": 4 },
        "background": { "activeOnStart": true, "beginsPattern": "VITE|vite|npm", "endsPattern": "ready in|Local:|localhost" }
      },
      "presentation": { "reveal": "silent", "panel": "dedicated", "group": "dev" }
    },
    {
      "label": "🔧 Admin UI",
      "detail": "neuro-admin en puerto 5174",
      "type": "shell",
      "command": "fuser -k 5174/tcp 2>/dev/null; sleep 0.3; source ~/.nvm/nvm.sh 2>/dev/null; cd neuro-admin && npm run dev",
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite-admin",
        "pattern": { "regexp": "^(.*):(\\d+):(\\d+): (.*)$", "file": 1, "line": 2, "column": 3, "message": 4 },
        "background": { "activeOnStart": true, "beginsPattern": "VITE|vite|npm", "endsPattern": "ready in|Local:|localhost" }
      },
      "presentation": { "reveal": "silent", "panel": "dedicated", "group": "dev" }
    },

    // =========================================================================
    // START ALL (with dependencies)
    // =========================================================================
    {
      "label": "🦀 Backend (wait for Docker)",
      "type": "shell",
      "command": "echo '⏳ Waiting for Docker...' && sleep 5 && fuser -k 3000/tcp 2>/dev/null; sleep 0.3; cd neuro-backend && cargo watch -x run",
      "isBackground": true,
      "options": {
        "env": {
          "DATABASE_URL": "ws://127.0.0.1:8000",
          "DATABASE_USER": "root",
          "DATABASE_PASS": "neuroos_secret_2024",
          "OLLAMA_URL": "http://127.0.0.1:11434",
          "SEARXNG_URL": "http://127.0.0.1:8080",
          "VOICE_SERVICE_URL": "http://127.0.0.1:8100",
          "MUSIC_SERVICE_URL": "http://127.0.0.1:3002",
          "CHECKLISTS_SERVICE_URL": "http://127.0.0.1:3001",
          "CHAT_SERVICE_URL": "http://127.0.0.1:3003",
          "MEMORY_SERVICE_URL": "http://127.0.0.1:3004",
          "AGENT_SERVICE_URL": "http://127.0.0.1:3005",
          "KANBAN_SERVICE_URL": "http://127.0.0.1:3006",
          "NOTE_SERVICE_URL": "http://127.0.0.1:3007",
          "DOCS_SERVICE_URL": "http://127.0.0.1:3008",
          "CALENDAR_SERVICE_URL": "http://127.0.0.1:3009",
          "POMODORO_SERVICE_URL": "http://127.0.0.1:3010",
          "IMAGE_SERVICE_URL": "http://127.0.0.1:3011",
          "RUST_LOG": "info"
        }
      },
      "problemMatcher": {
        "owner": "rust",
        "fileLocation": ["relative", "${workspaceFolder}/neuro-backend"],
        "pattern": { "regexp": "^error\\[E\\d+\\]: (.+)$", "message": 1 },
        "background": { "activeOnStart": true, "beginsPattern": "Compiling|Restarting|Waiting", "endsPattern": "NEURO-OS Backend ready|Server:" }
      },
      "presentation": { "reveal": "always", "panel": "dedicated", "group": "dev" },
      "dependsOn": ["🐳 Docker (Dev Mode)"]
    },
    {
      "label": "⚛️ User UI (wait for Backend)",
      "type": "shell",
      "command": "echo '⏳ Waiting for Backend...' && until curl -s http://localhost:3000/api/health > /dev/null 2>&1; do sleep 2; done && echo '✓ Backend ready!' && fuser -k 5173/tcp 2>/dev/null; sleep 0.3; source ~/.nvm/nvm.sh 2>/dev/null; cd neuro-ui && npm run dev",
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": { "regexp": "^(.*):(\\d+):(\\d+): (.*)$", "file": 1, "line": 2, "column": 3, "message": 4 },
        "background": { "activeOnStart": true, "beginsPattern": "VITE|vite|npm|Waiting", "endsPattern": "ready in|Local:|localhost" }
      },
      "presentation": { "reveal": "silent", "panel": "dedicated", "group": "dev" },
      "dependsOn": ["🦀 Backend (wait for Docker)"]
    },
    {
      "label": "🔧 Admin UI (wait for Backend)",
      "type": "shell",
      "command": "echo '⏳ Waiting for Backend...' && until curl -s http://localhost:3000/api/health > /dev/null 2>&1; do sleep 2; done && echo '✓ Backend ready!' && fuser -k 5174/tcp 2>/dev/null; sleep 0.3; source ~/.nvm/nvm.sh 2>/dev/null; cd neuro-admin && npm run dev",
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite-admin",
        "pattern": { "regexp": "^(.*):(\\d+):(\\d+): (.*)$", "file": 1, "line": 2, "column": 3, "message": 4 },
        "background": { "activeOnStart": true, "beginsPattern": "VITE|vite|npm|Waiting", "endsPattern": "ready in|Local:|localhost" }
      },
      "presentation": { "reveal": "silent", "panel": "dedicated", "group": "dev" },
      "dependsOn": ["🦀 Backend (wait for Docker)"]
    },
    {
      "label": "🚀 Start Full Stack",
      "detail": "Docker → Backend → User UI + Admin UI",
      "dependsOn": ["⚛️ User UI (wait for Backend)", "🔧 Admin UI (wait for Backend)"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    },

    // =========================================================================
    // UTILITIES
    // =========================================================================
    {
      "label": "🔨 Rebuild Backend (Clean)",
      "detail": "cargo clean + rebuild desde cero",
      "type": "shell",
      "command": "fuser -k 3000/tcp 2>/dev/null; pkill -f 'cargo watch' 2>/dev/null; sleep 0.5; cd neuro-backend && cargo clean && cargo watch -x run",
      "isBackground": true,
      "options": {
        "env": {
          "DATABASE_URL": "ws://127.0.0.1:8000",
          "DATABASE_USER": "root",
          "DATABASE_PASS": "neuroos_secret_2024",
          "OLLAMA_URL": "http://127.0.0.1:11434",
          "SEARXNG_URL": "http://127.0.0.1:8080",
          "VOICE_SERVICE_URL": "http://127.0.0.1:8100",
          "MUSIC_SERVICE_URL": "http://127.0.0.1:3002",
          "CHECKLISTS_SERVICE_URL": "http://127.0.0.1:3001",
          "CHAT_SERVICE_URL": "http://127.0.0.1:3003",
          "MEMORY_SERVICE_URL": "http://127.0.0.1:3004",
          "AGENT_SERVICE_URL": "http://127.0.0.1:3005",
          "KANBAN_SERVICE_URL": "http://127.0.0.1:3006",
          "NOTE_SERVICE_URL": "http://127.0.0.1:3007",
          "DOCS_SERVICE_URL": "http://127.0.0.1:3008",
          "CALENDAR_SERVICE_URL": "http://127.0.0.1:3009",
          "POMODORO_SERVICE_URL": "http://127.0.0.1:3010",
          "IMAGE_SERVICE_URL": "http://127.0.0.1:3011",
          "RUST_LOG": "warn"
        }
      },
      "problemMatcher": {
        "owner": "rust",
        "fileLocation": ["relative", "${workspaceFolder}/neuro-backend"],
        "pattern": { "regexp": "^error\\[E\\d+\\]: (.+)$", "message": 1 },
        "background": { "activeOnStart": true, "beginsPattern": "Compiling|Cleaning", "endsPattern": "NEURO-OS Backend ready|Server:" }
      },
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },
    {
      "label": "🧹 Clean Docker Cache",
      "detail": "Limpia cargo cache de contenedores Docker",
      "type": "shell",
      "command": "./dev.sh clean-cache",
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared" }
    }
  ]
}
