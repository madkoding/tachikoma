# =============================================================================
# Dockerfile.dev for tachikoma-chat (Development - Fast builds)
# =============================================================================

FROM rust:1.85-slim AS chef
RUN cargo install cargo-chef --locked
RUN apt-get update && apt-get install -y pkg-config libssl-dev mold && rm -rf /var/lib/apt/lists/*
WORKDIR /app

FROM chef AS planner
COPY Cargo.toml Cargo.lock* ./
COPY src ./src
RUN cargo chef prepare --recipe-path recipe.json

FROM chef AS builder
ENV RUSTFLAGS="-C link-arg=-fuse-ld=mold"
COPY --from=planner /app/recipe.json recipe.json
RUN cargo chef cook --recipe-path recipe.json

COPY Cargo.toml Cargo.lock* ./
COPY src ./src
RUN cargo build

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y ca-certificates curl && rm -rf /var/lib/apt/lists/*
WORKDIR /app
COPY --from=builder /app/target/debug/tachikoma-chat /app/tachikoma-chat
EXPOSE 3003
CMD ["/app/tachikoma-chat"]
