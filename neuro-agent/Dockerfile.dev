# ==============================================================================
# TACHIKOMA-AGENT Development Dockerfile (Fast builds with cargo-chef + mold)
# ==============================================================================

# ==============================================================================
# Stage 1: Chef with mold linker
# ==============================================================================
FROM rust:1.85-slim AS chef

# Install mold linker and cargo-chef for faster builds
RUN apt-get update && apt-get install -y \
    mold \
    pkg-config \
    libssl-dev \
    && rm -rf /var/lib/apt/lists/* \
    && cargo install cargo-chef --locked

# Configure mold as default linker
ENV RUSTFLAGS="-C link-arg=-fuse-ld=mold"

WORKDIR /app

# ==============================================================================
# Stage 2: Planner - Generate recipe.json
# ==============================================================================
FROM chef AS planner
COPY Cargo.toml Cargo.lock* ./
COPY src ./src
RUN cargo chef prepare --recipe-path recipe.json

# ==============================================================================
# Stage 3: Builder - Build dependencies (cached) then app (DEBUG mode)
# ==============================================================================
FROM chef AS builder

# Build dependencies (cached if recipe.json hasn't changed)
COPY --from=planner /app/recipe.json recipe.json
RUN cargo chef cook --recipe-path recipe.json

# Build application (debug mode for faster builds)
COPY Cargo.toml Cargo.lock* ./
COPY src ./src
RUN cargo build

# ==============================================================================
# Stage 4: Runtime
# ==============================================================================
FROM debian:bookworm-slim AS runtime

RUN apt-get update && apt-get install -y \
    ca-certificates \
    curl \
    coreutils \
    findutils \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy DEBUG binary (faster to build)
COPY --from=builder /app/target/debug/tachikoma-agent /app/tachikoma-agent

ENV HOST=0.0.0.0
ENV PORT=3005
ENV SEARXNG_URL=http://searxng:8080
ENV RUST_LOG=debug,tachikoma_agent=debug

EXPOSE 3005

CMD ["./tachikoma-agent"]
