# =============================================================================
# FAST DEV BUILD - Sin optimizaciones, con mold linker
# =============================================================================
FROM rust:1.83-slim AS builder

# Install build dependencies + mold linker for faster linking
RUN apt-get update && apt-get install -y \
    pkg-config \
    libssl-dev \
    mold \
    && rm -rf /var/lib/apt/lists/*

# Configure mold as default linker
ENV RUSTFLAGS="-C link-arg=-fuse-ld=mold"

WORKDIR /app

# Copy source
COPY Cargo.toml Cargo.lock* ./
COPY src ./src

# Build in debug mode (faster compilation)
RUN cargo build

# =============================================================================
# Runtime
# =============================================================================
FROM debian:bookworm-slim AS runtime

RUN apt-get update && apt-get install -y \
    ca-certificates \
    libssl3 \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy debug binary
COPY --from=builder /app/target/debug/neuro-kanban /app/neuro-kanban

EXPOSE 3006

HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:3006/api/health || exit 1

CMD ["./neuro-kanban"]
